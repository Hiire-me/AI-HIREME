# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Flask secret key — change to a long random string in production
SECRET_KEY=your-very-secret-key-change-this

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — Supabase (PostgreSQL) — recommended for cloud / production
# ─────────────────────────────────────────────────────────────────────────────
# Get your connection string from:
#   Supabase Dashboard → Project Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your actual database password.
# Example:
#   postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
#
# Leave blank to use local SQLite (development only).
DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — AI & Job APIs
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key (free at https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=

# Adzuna job search API (free at https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Resend email API key (free at https://resend.com)
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Redis / Celery (for background tasks)
# ─────────────────────────────────────────────────────────────────────────────
# If not set, background tasks run synchronously (fine for most use cases).
# Free Redis: https://upstash.com (serverless Redis)
REDIS_URL=

# ─────────────────────────────────────────────────────────────────────────────
# FLASK ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
